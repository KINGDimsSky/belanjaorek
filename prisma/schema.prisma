generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
}

enum Status {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  username            String              @unique
  password            String?
  role                Role                @default(user)
  image               String?             @default("/user.png")
  TwoVerificationStep Boolean             @default(false) @map("2fa")
  Cart                Cart?
  Product             Product[]
  Wishlist            Wishlist[]
  productCommentaries ProductCommentary[]
  userGivingStars     UserGivingStars[]

  @@index([email])
  @@map("users")
}

model Product {
  id                  String              @id @default(cuid())
  name                String
  slug                String              @unique
  price               Int
  MainImage           String?             @default("/NoProduct.jpg")
  IsDiscount          Boolean             @default(false) @map("isdiscount")
  Stock               Int
  status              Status              @default(DRAFT)
  DiscountPrice       Int?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  userId              String
  categoryId          String
  CartItems           CartItems[]
  category            Category            @relation(fields: [categoryId], references: [id])
  Seller              User                @relation(fields: [userId], references: [id])
  ProductDescription  ProductDescription?
  ProductImage        ProductImage[]
  Wishlist            Wishlist[]
  productVerified     ProductVerified?
  productCommentaries ProductCommentary[]
  userGivingStars     UserGivingStars[]

  @@index([status])
  @@index([slug])
  @@map("product")
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String  @unique
  name      String
  productId String
  Product   Product @relation(fields: [productId], references: [id])

  @@map("product_image")
}

model ProductDescription {
  id            String  @id @default(cuid())
  description   String
  productId     String  @unique
  LatestVersion String  @default("v1") @map("latestversion")
  Product       Product @relation(fields: [productId], references: [id])

  @@map("product_description")
}

model ProductVerified {
  id                String  @id @default(cuid())
  VerifiedProduct   Boolean @default(false) @map("verifiedproduct")
  productId         String  @unique
  LicensesAgreement String  @default("No Licenses") @map("licensesagreement")
  Product           Product @relation(fields: [productId], references: [id])

  @@map("verified_product")
}

model ProductCommentary {
  id         String    @id @default(cuid())
  subject    String
  commentary String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime? @updatedAt
  userId     String
  productId  String
  user       User      @relation(fields: [userId], references: [id])
  Product    Product   @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("comment")
}

model UserGivingStars {
  id        String @id @default(cuid())
  stars     Int
  userId    String
  productId String

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("product_stars")
}

model Wishlist {
  id        String  @id @default(cuid())
  userId    String
  productId String
  product   Product @relation(fields: [productId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
  @@map("wishlist")
}

model Cart {
  id        String      @id @default(cuid())
  userId    String      @unique
  user      User        @relation(fields: [userId], references: [id])
  CartItems CartItems[]

  @@map("cart")
}

model CartItems {
  id        String  @id @default(cuid())
  CartId    String
  productId String
  Quantity  Int     @default(1)
  Cart      Cart    @relation(fields: [CartId], references: [id])
  Product   Product @relation(fields: [productId], references: [id])

  @@unique([productId, CartId])
  @@map("cart_items")
}

model Category {
  id      String    @id @default(cuid())
  title   String
  slug    String
  Product Product[]

  @@unique([title, slug])
  @@map("category")
}
